        <Switch name="Enable_IZY_RMP_556pack" displayKey="ui_IZY_RMP_556pack" tooltipKey="tip_IZY_RMP_556pack" defaultValue="On" leftValue="Off" rightValue="On" />
        <Switch name="Enable_IZY_RMP_762pack" displayKey="ui_IZY_RMP_762pack" tooltipKey="tip_IZY_RMP_762pack" defaultValue="On" leftValue="Off" rightValue="On" />
