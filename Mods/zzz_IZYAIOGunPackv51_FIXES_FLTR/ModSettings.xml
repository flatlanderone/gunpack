        <Selector name="Enable_T4_DegradationSelector" displayKey="ui_Enable_T4_DegradationSelector" tooltipKey="tip_Enable_T4_DegradationSelector" defaultValue="Default">
          <Property type="arrayValues" allowedValues="Default,2x,3x,4x,5x" />
