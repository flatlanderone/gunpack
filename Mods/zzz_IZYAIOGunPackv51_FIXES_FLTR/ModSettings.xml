<?xml version="1.0" encoding="utf-8"?>
<ModSettings>
  <Global>
    <Tab name="LootSettings" displayKey="uiLootSettings" tooltipKey="tipLootSettings">
      <Category name="LootToiletPistols" displayKey="uiLootToiletPistols" tooltipKey="tipLootToiletPistols">
