        <Switch name="LootToiletPistolsFNS" displayKey="uiLootToiletPistolsFNS" tooltipKey="tipLootToiletPistolsFNS" defaultValue="No" leftValue="No" rightValue="Yes" />

      </Category>
	  <Category name="LootLODO" displayKey="uiLootLODO" tooltipKey="tipLootLODO">
	          <Switch name="LootLODOSafes" displayKey="uiLootLODOSafes" tooltipKey="tipLootLODOSafes" defaultValue="No" leftValue="No" rightValue="Yes" />
	          <Switch name="LootLODOPoliceCars" displayKey="uiLootLODOPoliceCars" tooltipKey="tipLootLODOPoliceCars" defaultValue="No" leftValue="No" rightValue="Yes" />
	  </Category>
    </Tab>
    <Tab name="KickSettings" displayKey="uiKickSettings" tooltipKey="tipKickSettings">
      <Category name="ItemGroups" displayKey="uiItemGroups" tooltipKey="tipItemGroups">
        <Switch name="KickAllFirearms" displayKey="uiKickAllFirearms" tooltipKey="tipKickAllFirearms" defaultValue="Kick On" leftValue="Kick Off" rightValue="Kick On" />
        <Switch name="KickAllBows" displayKey="uiKickAllBows" tooltipKey="tipKickAllBows" defaultValue="Kick On" leftValue="Kick Off" rightValue="Kick On" />
        <Switch name="KickAllMeleeWeapons" displayKey="uiKickAllMeleeWeapons" tooltipKey="tipAllMeleeWeapons" defaultValue="Kick Off" leftValue="Kick Off" rightValue="Kick On" />
        <Switch name="KickAllCommonTools" displayKey="uiKickAllCommonTools" tooltipKey="tipKickAllCommonTools" defaultValue="Kick Off" leftValue="Kick Off" rightValue="Kick On" />
        <Switch name="KickAllFlashlight" displayKey="uiKickAllFlashlight" tooltipKey="tipKickAllFlashlight" defaultValue="Kick Off" leftValue="Kick Off" rightValue="Kick On" />
      </Category>
      <Category name="NoteKick" displayKey="uiNoteKick" tooltipKey="tipNoteKick" />
      <Category name="NoteKick2" displayKey="uiNoteKick2" tooltipKey="tipNoteKick2" />
