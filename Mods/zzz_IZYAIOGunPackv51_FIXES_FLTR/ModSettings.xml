      </Category>
      <Category name="T4RepairCategory" displayKey="uiT4RepairCategory" tooltipKey="tipT4RepairCategory">
        <Switch name="Enable_T4_Repair" displayKey="ui_Enable_T4_Repair" tooltipKey="tip_Enable_T4_Repair" defaultValue="On" leftValue="Off" rightValue="On" />
