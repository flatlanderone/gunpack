<!-- *** IZY_RMP_Miscpack -->

<conditional>
<if cond="mod_loaded('IZY_RMP_Miscpack') and mod_version('IZY_RMP_Miscpack') = version(1,1,0,4)">

<!-- Start of 2.6.1.4 -->

<!-- Removed ammoMuzzleloaderscattershot from trader inventory. -->
<!-- <remove xpath="/traders/trader_item_groups/trader_item_group/item[@name='ammoMuzzleloaderscattershot']"/> -->

<!-- End of 2.6.1.4 -->

<!-- 2.6.1.1 -->
<!-- Added traderstage_template ammoTier0 to fix trader inventory crash due to Exception: TraderStageTemplate ammoTier0 for item: Muzzleloader Ammo does not exist. Bug:https://github.com/flatlanderone/gunpack/issues/9 (ammoMuzzleloadershot) reported by Black Wolf. -->

<insertBefore xpath="/traders/traderstage_templates/traderstage_template[@name='ammoTier1']">
	<traderstage_template name="ammoTier0"> <!-- Flintlock ammo from IZY 5.1.3 -->
		<entry min="1" max="999999" quality="0"/>
	</traderstage_template>
</insertBefore>
<!-- End of 2.6.1.1 -->
</if>
</conditional>



<!-- 2.6.1.0 -->
