<!-- *** IZY_RMP_556pack -->

<conditional>
<if cond="mod_loaded('IZY_RMP_556pack') and mod_version('IZY_RMP_556pack') = version(1,1,0,4)">

<!-- Made HP and AP 5.56mm (single round and bundle) recipes learnable. -->
