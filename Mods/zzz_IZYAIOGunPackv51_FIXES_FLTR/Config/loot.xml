<!-- *** IZY_RMP_44magnum -->

<conditional>
<if cond="mod_loaded('IZY_RMP_44magnum') and mod_version('IZY_RMP_44magnum') = version(1,1,0,4)">

<!-- Start of 2.6.1.4 -->
<!-- Added IZYgunT3PistolMagnumAutomag44 and IZYgunT4DualMagnumDesertEagles to loot. -->
<insertAfter xpath="//lootgroup[@name='groupWeaponsT3_Gunslinger']">
	<lootgroup name="groupWeaponsT3_IZYgunT3PistolMagnumAutomag44" count="all" loot_quality_template="QLTemplateT3">
		<item name="IZYgunT3PistolMagnumAutomag44"/>
	</lootgroup>
	<lootgroup name="groupWeaponsT4_IZYgunT4DualMagnumDesertEagles" count="all" loot_quality_template="QLTemplateT3">
		<item name="IZYgunT4DualMagnumDesertEagles"/>
	</lootgroup>
</insertAfter>
<append xpath="//lootgroup[@name='groupWeaponsT3_Ranged']">	
	<item group="groupWeaponsT3_IZYgunT3PistolMagnumAutomag44"/>
	<item group="groupWeaponsT4_IZYgunT4DualMagnumDesertEagles"/>
</append>
<append xpath="//lootgroup[@name='groupQuestWeaponsRangedT3']">	
	<item name="IZYgunT3PistolMagnumAutomag44"/>
	<item name="IZYgunT4DualMagnumDesertEagles"/>
</append>
<!-- End of 2.6.1.4 -->
</if>
</conditional>

<!-- Start of 2.6.1.5 -->

<!-- Added new probability templates by FNS.-->
<!-- Probability templates -->
<insertBefore xpath="//lootprobtemplate[@name='veryLow']">
	<lootprobtemplate name="minisculeLowFLTRIGP">
	<loot level="0,10" prob="0"/>
	<loot level="11,999999" prob=".16"/>  
	</lootprobtemplate>
</insertBefore>	

<insertBefore xpath="//lootprobtemplate[@name='veryLow']">
	<lootprobtemplate name="tinyLowFLTRIGP">
	<loot level="0,20" prob="0"/>
	<loot level="21,999999" prob=".12"/> 
	</lootprobtemplate>
</insertBefore>	

<insertBefore xpath="//lootprobtemplate[@name='veryLow']">
	<lootprobtemplate name="laughablyLowFLTRIGP">
	<loot level="0,50" prob="0"/>
	<loot level="51,999999" prob=".08"/> 
	</lootprobtemplate>
</insertBefore>	

<insertBefore xpath="//lootprobtemplate[@name='veryLow']">
	<lootprobtemplate name="stupidLowFLTRIGP">
	<loot level="0,70" prob="0"/>
	<loot level="71,999999" prob=".04"/> 
	</lootprobtemplate>
</insertBefore>	

<!-- Added common lootgroups for Options/loot.xml -->
<!-- Added common loot groups for common weapons.
TODO: Check if append in parent works.
  -->
<!-- Single group for big containers -->

<prepend xpath="/lootcontainers">
	<lootgroup name="groupCommonWeaponsFLTR" loot_quality_template="qualQ1Template">
		<item group="groupCommonSmallWeaponsFLTR"/>	
		<item group="groupCommonMediumWeaponsFLTR"/>
	</lootgroup>
</prepend>

<!-- Added groupCommonSmallWeaponsFLTR for small form-factorweapons that fit in smaller containers. -->

<prepend xpath="/lootcontainers">
	<lootgroup name="groupCommonSmallWeaponsFLTR" loot_quality_template="qualQ1Template">
		<item name="meleeWpnBladeT1HuntingKnife" loot_prob_template="minisculeLowFLTRIGP"/>
		<item name="meleeWpnKnucklesT1IronKnuckles" loot_prob_template="minisculeLowFLTRIGP"/>
		<item name="gunHandgunT1Pistol" loot_prob_template="minisculeLowFLTRIGP"/>
		<item name="IZYgunT1Pistol45M1917" loot_prob_template="minisculeLowFLTRIGP"/>
		<item name="IZYgunT1Pistol45Type17C96" loot_prob_template="minisculeLowFLTRIGP"/>
		<item name="IZYgunT1Pistol9Makarov" loot_prob_template="minisculeLowFLTRIGP"/>
		<item name="IZYgunT2Pistol45M1911A1" loot_prob_template="tinyLowFLTRIGP"/>
		<item name="gunHandgunT2Magnum44" loot_prob_template="tinyLowFLTRIGP"/>
		<item name="IZYgunT2Pistol45M1911A1" loot_prob_template="tinyLowFLTRIGP"/>
	</lootgroup>
</prepend>

